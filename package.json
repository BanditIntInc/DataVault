{
  "name": "@banditintinc/datavault",
  "version": "0.3.0",
  "description": "Framework-agnostic smart cache and observer data service. Fetch, cache, map, and broadcast any data source to any consumer — as a library or a microservice.",
  "keywords": ["cache", "observer", "data", "websocket", "rest", "polling", "typescript"],
  "author": "David Pardini",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BanditIntInc/DataVault"
  },
  "files": [
    "dist/lib",
    "dist/core",
    "!dist/core/__tests__",
    "!dist/core/cache/__tests__"
  ],
  "main": "./dist/lib/index.js",
  "module": "./dist/lib/index.mjs",
  "types": "./dist/lib/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "server": "ts-node server/index.ts",
    "wiki": "cd wiki && bundle exec gollum --config gollum_config.rb"
  },
  "dependencies": {
    "express": "^4.19.0",
    "ws": "^8.17.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "moduleFileExtensions": ["ts", "js"]
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.0",
    "@types/ws": "^8.5.0",
    "ts-node": "^10.9.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "@types/jest": "^29.0.0"
  }
}
